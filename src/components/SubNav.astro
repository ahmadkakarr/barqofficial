---
// src/components/SubNav.astro

const subMenus = {
    fiber: [
        { label: "PACKAGES", href: "/subscriptions" },
        { label: "COVERAGE", href: "#" },
        { label: "INSTALLATION", href: "#" },
    ],
    wireless: [
        { label: "PACKAGES", href: "/subscriptions" },
        { label: "FEASIBILITY", href: "#" },
    ],
    equipment: [
        { label: "ROUTERS & MESH", href: "#" },
        { label: "WIRELESS DISHES", href: "#" },
        { label: "ACCESSORIES", href: "#" },
    ],
    support: [
        { label: "FAQ", href: "/faq" },
        { label: "CONTACT US", href: "/contact" },
    ],
};
---

<div
    id="subnav-bar"
    class="hidden w-full bg-base-200 text-base-content border-b border-base-300 shadow-md relative z-30"
>
    <div class="max-w-[1440px] mx-auto px-4 lg:px-8">
        {/* Render each submenu dynamically */}
        {
            Object.entries(subMenus).map(([key, items]) => (
                <ul
                    id={`menu-${key}`}
                    class="submenu-list hidden flex items-center justify-center gap-12 h-14 text-sm font-bold tracking-wide"
                >
                    {items.map((item) => (
                        <li>
                            <a
                                href={item.href}
                                class="hover:text-primary transition-colors"
                            >
                                {item.label}
                            </a>
                        </li>
                    ))}
                </ul>
            ))
        }
    </div>
</div>
