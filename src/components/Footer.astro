---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer
    class="bg-base-100 text-base-content border-t border-base-300 py-12 mt-auto"
>
    <div class="max-w-[1440px] mx-auto px-4 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
            <div>
                <h3 class="font-bold text-lg mb-4">Our Services</h3>
                <ul class="space-y-3 text-sm">
                    <li>
                        <a
                            href="/#fiber"
                            class="hover:text-primary transition-colors"
                            >Fiber Internet</a>
                    </li>
                    <li>
                        <a
                            href="/#wireless"
                            class="hover:text-primary transition-colors"
                            >Wireless Broadband</a>
                    </li>
                    <li>
                        <a
                            href="/#equipment"
                            class="hover:text-primary transition-colors"
                            >Network Equipment</a>
                    </li>
                </ul>
            </div>
            <div>
                <h3 class="font-bold text-lg mb-4">Customer Support</h3>
                <ul class="space-y-3 text-sm">
                    <li>
                        <a
                            href="/customer-care"
                            class="hover:text-primary transition-colors"
                            >Customer Care</a>
                    </li>
                    <li>
                        <a
                            href="/contact"
                            class="hover:text-primary transition-colors"
                            >Contact Us</a>
                    </li>
                    <li>
                        <a
                            href="/faq"
                            class="hover:text-primary transition-colors"
                            >Help & FAQs</a>
                    </li>
                </ul>
            </div>
            <div>
                <h3 class="font-bold text-lg mb-4">Quick Links</h3>
                <ul class="space-y-3 text-sm">
                    <li>
                        <a
                            href="/subscriptions"
                            class="hover:text-primary transition-colors"
                            >View Subscriptions</a>
                    </li>
                    <li>
                        <a
                            href="/terms-of-use"
                            class="hover:text-primary transition-colors"
                            >Terms of Use</a>
                    </li>
                    <li>
                        <a
                            href="/privacy-policy"
                            class="hover:text-primary transition-colors"
                            >Privacy Policy</a>
                    </li>
                </ul>
            </div>
            <div>
                <h3 class="font-bold text-lg mb-4">Connect With Us</h3>
                <div class="flex gap-4 mb-8">
                    <button
                        class="btn btn-ghost btn-circle btn-sm"
                        aria-label="Facebook"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                            ></path></svg
                        >
                    </button>
                    <button
                        class="btn btn-ghost btn-circle btn-sm"
                        aria-label="X (Twitter)"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path d="M4 4l11.733 16h4.267l-11.733 -16z"
                            ></path><path
                                d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"
                            ></path></svg
                        >
                    </button>
                    <button
                        class="btn btn-ghost btn-circle btn-sm"
                        aria-label="YouTube"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"
                            ></path><polygon
                                points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"
                            ></polygon></svg
                        >
                    </button>
                </div>
            </div>
        </div>

        <div
            class="border-t border-base-300 pt-8 flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6"
        >
            <div
                class="flex flex-col lg:flex-row items-start lg:items-center gap-8"
            >
                <a
                    href="/"
                    class="flex items-center gap-3 hover:opacity-90 transition-transform hover:scale-105 active:scale-95"
                    aria-label="Barq Homepage"
                >
                    <img
                        src="/images/logos/logo-03.png"
                        alt="Barq Logo"
                        width="40"
                        height="40"
                        class="h-8 lg:h-10 w-auto object-contain"
                    />
                    <span
                        class="text-primary font-bold text-xl lg:text-2xl tracking-tighter uppercase"
                    >
                        Barq
                    </span>
                </a>

                <nav
                    class="flex flex-wrap gap-x-6 gap-y-2 text-xs font-medium opacity-75"
                >
                    <a
                        href="/privacy-policy"
                        class="hover:text-primary transition-colors"
                        >Privacy Policy</a
                    >
                    <a
                        href="/terms-of-use"
                        class="hover:text-primary transition-colors"
                        >Terms of Use</a
                    >
                    <a
                        href="/accessibility"
                        class="hover:text-primary transition-colors"
                        >Accessibility</a
                    >
                </nav>
            </div>
            <p class="text-xs opacity-60">
                © {currentYear} Barq Telecommunication Pvt Ltd. All rights reserved.
            </p>
        </div>
    </div>
</footer>
