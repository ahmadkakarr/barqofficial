---
// src/components/Navigation.astro
import UtilityBar from "./UtilityBar.astro";
import SubNav from "./SubNav.astro";
import MobileDrawer from "./MobileDrawer.astro";
---

<div class="drawer drawer-end">
    <input id="mobile-menu-drawer" type="checkbox" class="drawer-toggle" />

    <div class="drawer-content flex flex-col min-h-screen">
        <header
            id="smart-header"
            class="w-full flex flex-col sticky top-0 z-50 bg-base-100 shadow-sm transition-transform duration-300 ease-in-out translate-y-0"
        >
            <UtilityBar />

            <nav class="w-full text-base-content border-b border-base-300 h-16">
                <div
                    class="max-w-[1440px] mx-auto w-full px-4 lg:px-8 flex items-center justify-between h-full"
                >
                    <div class="flex items-center h-full lg:gap-12">
                        <a
                            href="/"
                            class="flex items-center gap-3 transition-transform hover:scale-105 active:scale-95"
                            aria-label="Barq Homepage"
                        >
                            <img
                                src="/images/logos/logo-03.png"
                                alt="Barq Logo"
                                width="40"
                                height="40"
                                class="h-8 lg:h-10 w-auto object-contain"
                            />
                            <span
                                class="text-primary font-bold text-xl lg:text-2xl tracking-tighter uppercase"
                            >
                                Barq
                            </span>
                        </a>

                        <ul
                            class="hidden lg:flex items-center gap-6 text-sm font-bold h-full"
                        >
                            <li>
                                <button
                                    class="nav-trigger hover:text-primary h-16 flex items-center gap-1 transition-colors"
                                    data-target="fiber"
                                >
                                    Fiber <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-4 w-4 transition-transform duration-200 icon-arrow"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                            </li>
                            <li>
                                <button
                                    class="nav-trigger hover:text-primary h-16 flex items-center gap-1 transition-colors"
                                    data-target="wireless"
                                >
                                    Wireless <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-4 w-4 transition-transform duration-200 icon-arrow"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                            </li>
                            <li>
                                <button
                                    class="nav-trigger hover:text-primary h-16 flex items-center gap-1 transition-colors"
                                    data-target="equipment"
                                >
                                    Equipment <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-4 w-4 transition-transform duration-200 icon-arrow"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                            </li>
                            <li>
                                <button
                                    class="nav-trigger hover:text-primary h-16 flex items-center gap-1 transition-colors"
                                    data-target="support"
                                >
                                    Customer Care <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-4 w-4 transition-transform duration-200 icon-arrow"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                            </li>
                        </ul>
                    </div>

                    <div class="flex-none lg:hidden">
                        <label
                            for="mobile-menu-drawer"
                            class="btn btn-square btn-ghost"
                            aria-label="Open Menu"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                class="inline-block w-6 h-6 stroke-current"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M4 6h16M4 12h16M4 18h16"></path></svg
                            >
                        </label>
                    </div>
                </div>
            </nav>
        </header>

        <SubNav />

        <main class="flex-1">
            <slot />
        </main>
    </div>

    <MobileDrawer />
</div>

<script>
    function setupInteractiveNav() {
        const triggers = document.querySelectorAll(".nav-trigger");
        const subnavBar = document.getElementById("subnav-bar");
        const submenus = document.querySelectorAll(".submenu-list");
        let activeTarget = null;

        if (!subnavBar || triggers.length === 0) return;

        function resetArrows() {
            triggers.forEach((t) => {
                const icon = t.querySelector(".icon-arrow");
                if (icon) icon.classList.remove("rotate-180");
            });
        }

        function closeAll() {
            subnavBar.classList.add("hidden");
            submenus.forEach((menu) => menu.classList.add("hidden"));
            resetArrows();
            activeTarget = null;
        }

        triggers.forEach((trigger) => {
            trigger.addEventListener("click", (e) => {
                e.stopPropagation();
                const targetId = trigger.getAttribute("data-target");
                const targetMenu = document.getElementById(`menu-${targetId}`);
                const arrowIcon = trigger.querySelector(".icon-arrow");

                if (activeTarget === targetId) {
                    closeAll();
                    return;
                }

                submenus.forEach((menu) => menu.classList.add("hidden"));
                resetArrows();

                subnavBar.classList.remove("hidden");
                if (targetMenu) targetMenu.classList.remove("hidden");
                if (arrowIcon) arrowIcon.classList.add("rotate-180");

                activeTarget = targetId;
            });
        });

        document.addEventListener("click", (e) => {
            const header = document.querySelector("header");
            if (
                header &&
                !header.contains(e.target as Node) &&
                !subnavBar.contains(e.target as Node)
            ) {
                closeAll();
            }
        });
    }

    // Smart Header Scroll Logic
    function setupSmartHeader() {
        const header = document.getElementById("smart-header");
        if (!header) return;

        let lastScrollY = window.scrollY;

        if (window._smartHeaderScrollFn) {
            window.removeEventListener("scroll", window._smartHeaderScrollFn);
        }

        window._smartHeaderScrollFn = () => {
            const currentScrollY = window.scrollY;

            if (currentScrollY < 100) {
                header.classList.remove("-translate-y-full");
                header.classList.add("translate-y-0");
            } else if (currentScrollY > lastScrollY) {
                header.classList.remove("translate-y-0");
                header.classList.add("-translate-y-full");

                const subnavBar = document.getElementById("subnav-bar");
                if (subnavBar && !subnavBar.classList.contains("hidden")) {
                    subnavBar.classList.add("hidden");
                }
            } else {
                header.classList.remove("-translate-y-full");
                header.classList.add("translate-y-0");
            }

            lastScrollY = currentScrollY;
        };

        window.addEventListener("scroll", window._smartHeaderScrollFn, {
            passive: true,
        });
    }

    function init() {
        setupInteractiveNav();
        setupSmartHeader();
    }

    init();
    document.addEventListener("astro:page-load", init);
</script>
