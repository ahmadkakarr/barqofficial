---
// src/components/Navigation.astro
import UtilityBar from "./UtilityBar.astro";
import SubNav from "./SubNav.astro";
import MobileDrawer from "./MobileDrawer.astro";
---

<div class="drawer">
    <input id="mobile-menu-drawer" type="checkbox" class="drawer-toggle" />

    <div class="drawer-content flex flex-col min-h-screen">
        <header
            class="w-full flex flex-col relative z-40 bg-base-100 shadow-sm"
        >
            <UtilityBar />

            <nav
                class="w-full text-base-content border-b border-base-300 h-16 flex items-center"
            >
                <div
                    class="max-w-[1440px] mx-auto w-full px-4 lg:px-8 flex items-center"
                >
                    <div class="flex-none lg:hidden mr-4">
                        <label
                            for="mobile-menu-drawer"
                            class="btn btn-square btn-ghost"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                class="inline-block w-6 h-6 stroke-current"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M4 6h16M4 12h16M4 18h16"></path></svg
                            >
                        </label>
                    </div>

                    <a
                        href="/"
                        class="text-primary font-bold text-2xl tracking-tighter pr-12 flex-1 lg:flex-none uppercase"
                    >
                        Barq
                    </a>

                    <ul
                        class="hidden lg:flex items-center gap-6 text-sm font-bold h-full"
                    >
                        <li>
                            <button
                                class="nav-trigger hover:text-primary h-16 flex items-center gap-1 transition-colors"
                                data-target="fiber"
                            >
                                Fiber <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-4 w-4 transition-transform duration-200 icon-arrow"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 9l-7 7-7-7"></path></svg
                                >
                            </button>
                        </li>
                        <li>
                            <button
                                class="nav-trigger hover:text-primary h-16 flex items-center gap-1 transition-colors"
                                data-target="wireless"
                            >
                                Wireless <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-4 w-4 transition-transform duration-200 icon-arrow"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 9l-7 7-7-7"></path></svg
                                >
                            </button>
                        </li>
                        <li>
                            <button
                                class="nav-trigger hover:text-primary h-16 flex items-center gap-1 transition-colors"
                                data-target="equipment"
                            >
                                Equipment <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-4 w-4 transition-transform duration-200 icon-arrow"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 9l-7 7-7-7"></path></svg
                                >
                            </button>
                        </li>
                        <li>
                            <button
                                class="nav-trigger hover:text-primary h-16 flex items-center gap-1 transition-colors"
                                data-target="support"
                            >
                                Customer Care <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-4 w-4 transition-transform duration-200 icon-arrow"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 9l-7 7-7-7"></path></svg
                                >
                            </button>
                        </li>
                    </ul>
                </div>
            </nav>
        </header>

        <SubNav />

        <main class="flex-1">
            <slot />
        </main>
    </div>

    <MobileDrawer />
</div>

<script>
    function setupInteractiveNav() {
        const triggers = document.querySelectorAll(".nav-trigger");
        const subnavBar = document.getElementById("subnav-bar");
        const submenus = document.querySelectorAll(".submenu-list");
        let activeTarget = null;

        if (!subnavBar || triggers.length === 0) return;

        // Function to reset all arrows to default pointing down
        function resetArrows() {
            triggers.forEach((t) => {
                const icon = t.querySelector(".icon-arrow");
                if (icon) icon.classList.remove("rotate-180");
            });
        }

        // Function to close everything
        function closeAll() {
            subnavBar.classList.add("hidden");
            submenus.forEach((menu) => menu.classList.add("hidden"));
            resetArrows();
            activeTarget = null;
        }

        triggers.forEach((trigger) => {
            trigger.addEventListener("click", (e) => {
                e.stopPropagation();
                const targetId = trigger.getAttribute("data-target");
                const targetMenu = document.getElementById(`menu-${targetId}`);
                const arrowIcon = trigger.querySelector(".icon-arrow");

                // If user clicks the exact same menu that is currently open, close it.
                if (activeTarget === targetId) {
                    closeAll();
                    return;
                }

                // Otherwise, prepare to open the new one by closing others first
                submenus.forEach((menu) => menu.classList.add("hidden"));
                resetArrows();

                // Open the selected menu and rotate its arrow
                subnavBar.classList.remove("hidden");
                if (targetMenu) targetMenu.classList.remove("hidden");
                if (arrowIcon) arrowIcon.classList.add("rotate-180");

                activeTarget = targetId;
            });
        });

        // Close the subnav if the user clicks anywhere outside of the header/subnav
        document.addEventListener("click", (e) => {
            const header = document.querySelector("header");
            if (
                header &&
                !header.contains(e.target as Node) &&
                !subnavBar.contains(e.target as Node)
            ) {
                closeAll();
            }
        });
    }

    // Initialize the logic
    setupInteractiveNav();

    // If you are using Astro ViewTransitions, ensure the script re-runs on page navigation
    document.addEventListener("astro:page-load", setupInteractiveNav);
</script>
