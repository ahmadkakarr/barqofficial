---
// src/components/MobileDrawer.astro

const menus = {
    fiber: [
        { label: "Packages", href: "/subscriptions" },
        { label: "Coverage", href: "#" },
        { label: "Installation", href: "#" },
    ],
    wireless: [
        { label: "Packages", href: "/subscriptions" },
        { label: "Feasibility", href: "#" },
    ],
    equipment: [
        { label: "Routers & Mesh", href: "#" },
        { label: "Wireless Dishes", href: "#" },
        { label: "Accessories", href: "#" },
    ],
};
---

<div class="drawer-side z-[100]">
    <label for="mobile-menu-drawer" class="drawer-overlay"></label>

    <div
        class="w-full max-w-sm min-h-full bg-base-100 text-base-content relative overflow-hidden"
    >
        <div
            class="flex justify-between items-center p-4 border-b border-base-300 h-16 absolute top-0 left-0 w-full z-10 bg-base-100"
        >
            <button
                id="mobile-back-btn"
                class="hidden text-base-content/70 hover:text-primary"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="w-6 h-6"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15.75 19.5L8.25 12l7.5-7.5"></path></svg
                >
            </button>
            <span
                id="mobile-menu-title"
                class="font-bold text-lg hidden absolute left-12"></span>

            <label
                for="mobile-menu-drawer"
                class="ml-auto cursor-pointer text-base-content/70 hover:text-base-content"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="w-7 h-7"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6 18L18 6M6 6l12 12"></path></svg
                >
            </label>
        </div>

        <div class="pt-16 h-full w-full relative">
            <ul
                id="mobile-pane-main"
                class="menu p-0 w-full bg-base-100 text-lg transition-transform duration-300 absolute w-full left-0"
            >
                <li>
                    <button
                        class="mobile-drill-btn py-4 border-b border-base-300 font-bold flex justify-between rounded-none"
                        data-target="pane-fiber"
                        data-title="Fiber"
                    >
                        Fiber <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-5 h-5"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
                        >
                    </button>
                </li>
                <li>
                    <button
                        class="mobile-drill-btn py-4 border-b border-base-300 font-bold flex justify-between rounded-none"
                        data-target="pane-wireless"
                        data-title="Wireless"
                    >
                        Wireless <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-5 h-5"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
                        >
                    </button>
                </li>
                <li>
                    <button
                        class="mobile-drill-btn py-4 border-b border-base-300 font-bold flex justify-between rounded-none"
                        data-target="pane-equipment"
                        data-title="Equipment"
                    >
                        Equipment <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-5 h-5"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
                        >
                    </button>
                </li>
            </ul>

            {
                Object.entries(menus).map(([key, items]) => (
                    <ul
                        id={`pane-${key}`}
                        class="mobile-sub-pane menu p-0 w-full bg-base-100 text-lg transition-transform duration-300 absolute left-full"
                    >
                        {items.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class="py-4 border-b border-base-300 font-normal flex justify-between"
                                >
                                    {item.label}{" "}
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor"
                                        class="w-5 h-5 text-base-content/40"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M8.25 4.5l7.5 7.5-7.5 7.5"
                                        />
                                    </svg>
                                </a>
                            </li>
                        ))}
                    </ul>
                ))
            }
        </div>
    </div>
</div>

<script>
    // Astro will bundle this script automatically
    const drillBtns = document.querySelectorAll(".mobile-drill-btn");
    const btnBack = document.getElementById("mobile-back-btn");
    const paneMain = document.getElementById("mobile-pane-main");
    const subPanes = document.querySelectorAll(".mobile-sub-pane");
    const title = document.getElementById("mobile-menu-title");

    let activePane = null;

    if (drillBtns.length > 0 && btnBack && paneMain) {
        drillBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const targetId = btn.getAttribute("data-target");
                const menuTitle = btn.getAttribute("data-title");
                activePane = document.getElementById(targetId);

                if (activePane) {
                    paneMain.style.transform = "translateX(-100%)";
                    activePane.style.transform = "translateX(-100%)";

                    if (title) title.textContent = menuTitle;

                    btnBack.classList.remove("hidden");
                    title.classList.remove("hidden");
                }
            });
        });

        btnBack.addEventListener("click", () => {
            paneMain.style.transform = "translateX(0)";
            if (activePane) {
                activePane.style.transform = "translateX(0)";
                activePane = null;
            }
            btnBack.classList.add("hidden");
            if (title) title.classList.add("hidden");
        });
    }
</script>
