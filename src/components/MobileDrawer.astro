---
// src/components/MobileDrawer.astro

const menus = {
    fiber: [
        { label: "Packages", href: "/subscriptions" },
        { label: "Coverage", href: "/coverage" },
        { label: "Installation", href: "#" },
    ],
    wireless: [
        { label: "Packages", href: "/subscriptions" },
        { label: "Feasibility", href: "#" },
    ],
    equipment: [
        { label: "Routers & Mesh", href: "#" },
        { label: "Wireless Dishes", href: "#" },
        { label: "Accessories", href: "#" },
    ],
    support: [
        { label: "Help & FAQs", href: "/faq" },
        { label: "Contact Us", href: "/contact" },
        { label: "Customer Care", href: "/customer-care" },
    ],
};
---

<div class="drawer-side z-[100]">
    <label
        for="mobile-menu-drawer"
        class="drawer-overlay"
        aria-label="Close menu"></label>

    <div
        class="w-full max-w-sm min-h-full bg-base-100 text-base-content flex flex-col relative shadow-2xl"
    >
        <div
            class="px-4 py-4 border-b border-base-200 shrink-0 bg-base-100 z-20"
        >
            <div
                class="bg-base-200/70 p-1 rounded-full flex text-sm font-bold relative"
            >
                <button
                    class="flex-1 py-2 text-center rounded-full bg-base-100 shadow-sm text-primary transition-all"
                    >Personal</button
                >
                <button
                    class="flex-1 py-2 text-center rounded-full text-base-content/60 hover:text-base-content transition-all"
                    >Business</button
                >
            </div>
        </div>

        <div
            class="flex justify-between items-center px-4 border-b border-base-200 h-16 shrink-0 relative bg-base-100 z-20"
        >
            <button
                id="mobile-back-btn"
                class="hidden btn btn-ghost btn-circle btn-sm text-base-content/70 hover:text-primary z-30 relative"
                aria-label="Go Back"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                    stroke="currentColor"
                    class="w-5 h-5"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15.75 19.5L8.25 12l7.5-7.5"></path></svg
                >
            </button>

            <div id="mobile-back-placeholder" class="w-8 h-8 z-30"></div>

            <div
                class="absolute inset-0 flex items-center justify-center pointer-events-none z-10"
            >
                <a
                    href="/"
                    class="flex items-center justify-center gap-2 transition-transform active:scale-95 pointer-events-auto"
                    aria-label="Home"
                >
                    <img
                        src="/images/logos/logo-03.png"
                        alt="Barq Logo"
                        width="32"
                        height="32"
                        class="h-8 w-auto object-contain"
                    />
                    <span
                        class="text-primary font-bold text-xl tracking-tighter uppercase"
                        >Barq</span
                    >
                </a>
            </div>

            <label
                for="mobile-menu-drawer"
                class="btn btn-ghost btn-circle btn-sm text-base-content/70 hover:text-base-content z-30 relative cursor-pointer"
                aria-label="Close menu"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                    stroke="currentColor"
                    class="w-6 h-6"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6 18L18 6M6 6l12 12"></path></svg
                >
            </label>
        </div>

        <div class="flex-1 relative w-full h-full overflow-hidden">
            <ul
                id="mobile-pane-main"
                class="absolute inset-0 flex flex-col w-full m-0 p-0 bg-base-100 transition-transform duration-300 ease-in-out translate-x-0 overflow-y-auto pb-8"
            >
                <li class="w-full border-b border-base-200">
                    <button
                        class="mobile-drill-btn w-full py-4 px-6 font-bold text-base flex justify-between items-center hover:bg-base-200/50"
                        data-target="pane-fiber"
                    >
                        Fiber <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            class="w-4 h-4 text-base-content/40"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
                        >
                    </button>
                </li>
                <li class="w-full border-b border-base-200">
                    <button
                        class="mobile-drill-btn w-full py-4 px-6 font-bold text-base flex justify-between items-center hover:bg-base-200/50"
                        data-target="pane-wireless"
                    >
                        Wireless <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            class="w-4 h-4 text-base-content/40"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
                        >
                    </button>
                </li>
                <li class="w-full border-b border-base-200">
                    <button
                        class="mobile-drill-btn w-full py-4 px-6 font-bold text-base flex justify-between items-center hover:bg-base-200/50"
                        data-target="pane-equipment"
                    >
                        Equipment <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            class="w-4 h-4 text-base-content/40"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
                        >
                    </button>
                </li>
                <li class="w-full border-b border-base-200">
                    <button
                        class="mobile-drill-btn w-full py-4 px-6 font-bold text-base flex justify-between items-center hover:bg-base-200/50"
                        data-target="pane-support"
                    >
                        Support <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            class="w-4 h-4 text-base-content/40"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
                        >
                    </button>
                </li>

                <li class="w-full mt-4 px-4">
                    <span
                        class="block text-xs font-bold uppercase opacity-50 px-2 py-1 tracking-wider"
                        >Quick Links</span
                    >
                </li>
                <li class="w-full">
                    <a
                        href="tel:03364011111"
                        class="block w-full py-3 px-6 font-medium text-base-content/80 active:bg-base-200"
                        ><span class="text-primary mr-2">📞</span> 0336 4011111</a
                    >
                </li>
                <li class="w-full">
                    <a
                        href="#"
                        class="block w-full py-3 px-6 font-medium text-base-content/80 active:bg-base-200"
                        >Stores</a
                    >
                </li>
                <li class="w-full">
                    <a
                        href="/coverage"
                        class="block w-full py-3 px-6 font-medium text-base-content/80 active:bg-base-200"
                        >Coverage Map</a
                    >
                </li>
                <li class="w-full">
                    <a
                        href="#"
                        class="block w-full py-3 px-6 font-medium text-base-content/80 active:bg-base-200"
                        >Español</a
                    >
                </li>
            </ul>

            {
                Object.entries(menus).map(([key, items]) => (
                    <ul
                        id={`pane-${key}`}
                        class="mobile-sub-pane absolute inset-0 flex flex-col w-full m-0 p-0 bg-base-100 transition-transform duration-300 ease-in-out translate-x-full overflow-y-auto pb-8"
                    >
                        {items.map((item) => (
                            <li class="w-full border-b border-base-200">
                                <a
                                    href={item.href}
                                    class="mobile-link block w-full py-4 px-6 font-medium text-base active:bg-primary/10"
                                >
                                    {item.label}
                                </a>
                            </li>
                        ))}
                    </ul>
                ))
            }
        </div>
    </div>
</div>

<script>
    function initMobileDrawer() {
        const STORAGE_KEY = "barq_mobile_nav_state";
        let activePaneId = sessionStorage.getItem(STORAGE_KEY) || null;

        // DETERMINISTIC UI RENDERER: Always queries the live DOM to prevent "ghost" elements
        function renderUI(animate = true) {
            const paneMain = document.getElementById("mobile-pane-main");
            const btnBack = document.getElementById("mobile-back-btn");
            const placeholder = document.getElementById(
                "mobile-back-placeholder",
            );
            const subPanes = document.querySelectorAll(".mobile-sub-pane");

            if (!paneMain) return;

            // Remove animations instantly if snapping on load
            if (!animate) {
                paneMain.classList.remove("transition-transform");
                subPanes.forEach((p) =>
                    p.classList.remove("transition-transform"),
                );
            }

            if (activePaneId) {
                // WE ARE IN A SUB-MENU: Slide main out, slide sub in. Show Back Button.
                paneMain.classList.remove("translate-x-0");
                paneMain.classList.add("-translate-x-full");

                subPanes.forEach((pane) => {
                    if (pane.id === activePaneId) {
                        pane.classList.remove("translate-x-full");
                        pane.classList.add("translate-x-0");
                    } else {
                        pane.classList.remove("translate-x-0");
                        pane.classList.add("translate-x-full");
                    }
                });

                if (btnBack) btnBack.classList.remove("hidden");
                if (placeholder) placeholder.classList.add("hidden");
            } else {
                // WE ARE IN THE ROOT MENU: Slide main in, slide subs out. Hide Back Button.
                paneMain.classList.remove("-translate-x-full");
                paneMain.classList.add("translate-x-0");

                subPanes.forEach((pane) => {
                    pane.classList.remove("translate-x-0");
                    pane.classList.add("translate-x-full");
                });

                if (btnBack) btnBack.classList.add("hidden");
                if (placeholder) placeholder.classList.remove("hidden");
            }

            // Restore animations safely after layout calculation
            if (!animate) {
                setTimeout(() => {
                    if (paneMain)
                        paneMain.classList.add("transition-transform");
                    subPanes.forEach((p) =>
                        p.classList.add("transition-transform"),
                    );
                }, 50);
            }
        }

        // 1. Initial Load (Snap instantly to saved state)
        renderUI(false);

        // 2. Attach Listeners cleanly
        const drillBtns = document.querySelectorAll(".mobile-drill-btn");
        drillBtns.forEach((btn) => {
            const newBtn = btn.cloneNode(true) as HTMLButtonElement;
            btn.parentNode?.replaceChild(newBtn, btn);
            newBtn.addEventListener("click", () => {
                activePaneId = newBtn.getAttribute("data-target");
                if (activePaneId) {
                    sessionStorage.setItem(STORAGE_KEY, activePaneId);
                    renderUI(true);
                }
            });
        });

        const btnBackRaw = document.getElementById("mobile-back-btn");
        if (btnBackRaw) {
            const newBtnBack = btnBackRaw.cloneNode(true) as HTMLButtonElement;
            btnBackRaw.parentNode?.replaceChild(newBtnBack, btnBackRaw);
            newBtnBack.addEventListener("click", () => {
                activePaneId = null;
                sessionStorage.removeItem(STORAGE_KEY);
                renderUI(true);
            });
        }

        const mobileLinks = document.querySelectorAll(
            ".mobile-link, #mobile-pane-main a[href]",
        );
        const drawerCheckbox = document.getElementById(
            "mobile-menu-drawer",
        ) as HTMLInputElement;
        mobileLinks.forEach((link) => {
            const newLink = link.cloneNode(true) as HTMLAnchorElement;
            link.parentNode?.replaceChild(newLink, link);
            newLink.addEventListener("click", () => {
                if (drawerCheckbox) drawerCheckbox.checked = false;
            });
        });
    }

    // Initialize resiliently
    initMobileDrawer();
    document.addEventListener("astro:page-load", initMobileDrawer);
</script>
