---
// src/components/MobileDrawer.astro

const menus = {
    fiber: [
        { label: "Packages", href: "/subscriptions" },
        { label: "Coverage", href: "#" },
        { label: "Installation", href: "#" },
    ],
    wireless: [
        { label: "Packages", href: "/subscriptions" },
        { label: "Feasibility", href: "#" },
    ],
    equipment: [
        { label: "Routers & Mesh", href: "#" },
        { label: "Wireless Dishes", href: "#" },
        { label: "Accessories", href: "#" },
    ],
    support: [
        { label: "Help & FAQs", href: "/faq" },
        { label: "Contact Us", href: "/contact" },
        { label: "Customer Care", href: "/customer-care" },
    ],
};
---

<div class="drawer-side z-[100]">
    <label
        for="mobile-menu-drawer"
        class="drawer-overlay"
        aria-label="Close menu"></label>

    <div
        class="w-full max-w-sm min-h-full bg-base-100 text-base-content flex flex-col relative pb-24 shadow-2xl"
    >
        <div
            class="px-4 py-4 border-b border-base-200 shrink-0 bg-base-100 z-20"
        >
            <div
                class="bg-base-200/70 p-1 rounded-full flex text-sm font-bold relative"
            >
                <button
                    class="flex-1 py-2 text-center rounded-full bg-base-100 shadow-sm text-primary transition-all"
                    >Personal</button
                >
                <button
                    class="flex-1 py-2 text-center rounded-full text-base-content/60 hover:text-base-content transition-all"
                    >Business</button
                >
            </div>
        </div>

        <div
            class="flex justify-center items-center p-4 border-b border-base-200 h-16 shrink-0 relative bg-base-100 z-20"
        >
            <div
                class="relative flex items-center justify-center w-full h-full"
            >
                <a
                    href="/"
                    id="mobile-drawer-logo"
                    class="flex items-center gap-2 transition-all duration-300 active:scale-95"
                >
                    <img
                        src="/images/logos/logo-03.png"
                        alt="Barq Logo"
                        width="32"
                        height="32"
                        class="h-8 w-auto object-contain"
                    />
                    <span
                        class="text-primary font-bold text-xl tracking-tighter uppercase"
                        >Barq</span
                    >
                </a>
                <span
                    id="mobile-menu-title"
                    class="font-bold text-lg tracking-tight uppercase absolute opacity-0 scale-95 transition-all duration-300 text-primary"
                ></span>
            </div>
        </div>

        <div class="flex-1 relative w-full h-full overflow-hidden">
            <ul
                id="mobile-pane-main"
                class="absolute inset-0 menu p-0 w-full bg-base-100 transition-transform duration-300 ease-in-out translate-x-0 overflow-y-auto"
            >
                <li>
                    <button
                        class="mobile-drill-btn py-4 px-6 border-b border-base-200 font-bold text-base flex justify-between rounded-none hover:bg-base-200/50"
                        data-target="pane-fiber"
                        data-title="Fiber"
                    >
                        Fiber <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            class="w-4 h-4 text-base-content/40"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
                        >
                    </button>
                </li>
                <li>
                    <button
                        class="mobile-drill-btn py-4 px-6 border-b border-base-200 font-bold text-base flex justify-between rounded-none hover:bg-base-200/50"
                        data-target="pane-wireless"
                        data-title="Wireless"
                    >
                        Wireless <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            class="w-4 h-4 text-base-content/40"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
                        >
                    </button>
                </li>
                <li>
                    <button
                        class="mobile-drill-btn py-4 px-6 border-b border-base-200 font-bold text-base flex justify-between rounded-none hover:bg-base-200/50"
                        data-target="pane-equipment"
                        data-title="Equipment"
                    >
                        Equipment <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            class="w-4 h-4 text-base-content/40"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
                        >
                    </button>
                </li>
                <li>
                    <button
                        class="mobile-drill-btn py-4 px-6 border-b border-base-200 font-bold text-base flex justify-between rounded-none hover:bg-base-200/50"
                        data-target="pane-support"
                        data-title="Support"
                    >
                        Support <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            class="w-4 h-4 text-base-content/40"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
                        >
                    </button>
                </li>

                <li class="mt-4 px-4">
                    <span
                        class="text-xs font-bold uppercase opacity-50 px-2 py-1 tracking-wider"
                        >Quick Links</span
                    >
                </li>
                <li>
                    <a
                        href="tel:03364011111"
                        class="py-3 px-6 font-medium text-base-content/80 rounded-none"
                        ><span class="text-primary mr-2">📞</span> 0336-4011111</a
                    >
                </li>
                <li>
                    <a
                        href="#"
                        class="py-3 px-6 font-medium text-base-content/80 rounded-none"
                        >Stores</a
                    >
                </li>
                <li>
                    <a
                        href="#"
                        class="py-3 px-6 font-medium text-base-content/80 rounded-none"
                        >Coverage Map</a
                    >
                </li>
                <li>
                    <a
                        href="#"
                        class="py-3 px-6 font-medium text-base-content/80 rounded-none"
                        >Español</a
                    >
                </li>
            </ul>

            {
                Object.entries(menus).map(([key, items]) => (
                    <ul
                        id={`pane-${key}`}
                        class="mobile-sub-pane absolute inset-0 menu p-0 w-full bg-base-100 transition-transform duration-300 ease-in-out translate-x-full overflow-y-auto"
                    >
                        {items.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class="mobile-link py-4 px-6 border-b border-base-200 font-medium text-base flex justify-between rounded-none active:bg-primary/10"
                                >
                                    {item.label}
                                </a>
                            </li>
                        ))}
                    </ul>
                ))
            }
        </div>

        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-50">
            <div
                class="bg-base-300 shadow-xl rounded-full p-1.5 flex items-center border border-base-content/10 transition-all duration-300"
            >
                <button
                    id="mobile-back-btn"
                    class="hidden btn btn-sm btn-ghost rounded-full px-5 font-bold text-base-content hover:bg-base-200 gap-1.5 transition-all duration-300"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="2.5"
                        stroke="currentColor"
                        class="w-4 h-4"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15.75 19.5L8.25 12l7.5-7.5"></path></svg
                    >
                    Back
                </button>

                <label
                    for="mobile-menu-drawer"
                    class="btn btn-sm btn-ghost rounded-full px-5 font-bold text-base-content hover:bg-base-200 gap-1.5 cursor-pointer transition-all duration-300"
                >
                    Close
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="2.5"
                        stroke="currentColor"
                        class="w-4 h-4"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M6 18L18 6M6 6l12 12"></path></svg
                    >
                </label>
            </div>
        </div>
    </div>
</div>

<script>
    function initMobileDrawer() {
        const drillBtns = document.querySelectorAll(".mobile-drill-btn");
        const btnBack = document.getElementById("mobile-back-btn");
        const paneMain = document.getElementById("mobile-pane-main");
        const title = document.getElementById("mobile-menu-title");
        const logo = document.getElementById("mobile-drawer-logo");
        const drawerCheckbox = document.getElementById(
            "mobile-menu-drawer",
        ) as HTMLInputElement;
        const mobileLinks = document.querySelectorAll(
            ".mobile-link, #mobile-pane-main a[href]",
        );

        let activePane: HTMLElement | null = null;

        function closeSubPane() {
            // Restore main pane
            if (paneMain) {
                paneMain.classList.remove("-translate-x-full");
                paneMain.classList.add("translate-x-0");
            }
            // Hide active pane
            if (activePane) {
                activePane.classList.remove("translate-x-0");
                activePane.classList.add("translate-x-full");
                activePane = null;
            }

            // Hide Back button in the floating pill
            if (btnBack) btnBack.classList.add("hidden");

            // Swap Title back to Logo safely
            if (title && logo) {
                title.classList.add("opacity-0", "scale-95");
                setTimeout(() => {
                    logo.classList.remove("opacity-0", "scale-95");
                }, 150);
            }
        }

        // Drill down into submenu
        drillBtns.forEach((btn) => {
            const newBtn = btn.cloneNode(true) as HTMLButtonElement;
            btn.parentNode?.replaceChild(newBtn, btn);

            newBtn.addEventListener("click", () => {
                const targetId = newBtn.getAttribute("data-target");
                const menuTitle = newBtn.getAttribute("data-title");
                activePane = document.getElementById(targetId as string);

                if (activePane && paneMain) {
                    // Hide main pane
                    paneMain.classList.remove("translate-x-0");
                    paneMain.classList.add("-translate-x-full");

                    // Show target pane
                    activePane.classList.remove("translate-x-full");
                    activePane.classList.add("translate-x-0");

                    // Show Back button in the floating pill
                    if (btnBack) btnBack.classList.remove("hidden");

                    // Swap Logo to Title smoothly
                    if (title && logo) {
                        logo.classList.add("opacity-0", "scale-95");
                        setTimeout(() => {
                            title.textContent = menuTitle;
                            title.classList.remove("opacity-0", "scale-95");
                        }, 150);
                    }
                }
            });
        });

        // Back button logic
        if (btnBack) {
            const newBtnBack = btnBack.cloneNode(true) as HTMLButtonElement;
            btnBack.parentNode?.replaceChild(newBtnBack, btnBack);
            newBtnBack.addEventListener("click", closeSubPane);
        }

        // Auto-close drawer and reset panes when a link is clicked
        mobileLinks.forEach((link) => {
            const newLink = link.cloneNode(true) as HTMLAnchorElement;
            link.parentNode?.replaceChild(newLink, link);

            newLink.addEventListener("click", () => {
                if (drawerCheckbox) drawerCheckbox.checked = false;
                setTimeout(closeSubPane, 300); // Wait for sliding animation to finish
            });
        });
    }

    initMobileDrawer();
    document.addEventListener("astro:page-load", initMobileDrawer);
</script>
