---
// src/components/FloatingContact.astro
---

<div
    class="fixed bottom-6 right-6 z-[99] flex flex-col-reverse items-end gap-3 font-sans"
>
    <button
        id="fab-toggle"
        class="btn btn-circle btn-primary shadow-2xl w-14 h-14 relative"
        aria-label="Contact Options"
    >
        <svg
            id="fab-icon-open"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-6 h-6 absolute transition-all duration-300 rotate-0 scale-100 opacity-100"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"
            ></path>
        </svg>

        <svg
            id="fab-icon-close"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6 absolute transition-all duration-300 -rotate-90 scale-50 opacity-0"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 18L18 6M6 6l12 12"></path>
        </svg>
    </button>

    <div
        id="fab-menu"
        class="flex flex-col items-end gap-3 transition-all duration-300 origin-bottom translate-y-4 opacity-0 pointer-events-none mb-1"
    >
        <div class="flex items-center gap-3">
            <span
                class="bg-base-100 text-base-content font-bold text-sm px-3 py-1.5 rounded-xl shadow-md border border-base-200 select-none"
                >WhatsApp</span
            >
            <a
                href="https://wa.me/923364011111"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-circle shadow-lg border-none w-12 h-12 min-h-0 bg-[#25D366] hover:bg-[#1ebd5a] text-white transition-transform hover:scale-110"
                aria-label="WhatsApp"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="22"
                    height="22"
                    fill="currentColor"
                    viewBox="0 0 16 16"
                >
                    <path
                        d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.005-.247-.005-.38-.005a.76.76 0 0 0-.546.248c-.182.198-.703.686-.703 1.673s.722 1.939.822 2.071c.099.133 1.412 2.155 3.42 3.023.479.206.854.329 1.147.42.482.153.922.131 1.27.079.388-.057 1.192-.487 1.36-9.58.168-.47.168-.871.118-.956-.05-.084-.182-.133-.38-.232z"
                    ></path>
                </svg>
            </a>
        </div>

        <div class="flex items-center gap-3">
            <span
                class="bg-base-100 text-base-content font-bold text-sm px-3 py-1.5 rounded-xl shadow-md border border-base-200 select-none"
                >Call Us</span
            >
            <a
                href="tel:03364011111"
                class="btn btn-circle shadow-lg border-none w-12 h-12 min-h-0 bg-info hover:bg-info/80 text-white transition-transform hover:scale-110"
                aria-label="Call"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="w-5 h-5"
                >
                    <path
                        fill-rule="evenodd"
                        d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1.5 1.5 0 011.465 1.175l.716 3.223a1.5 1.5 0 01-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 006.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 011.767-1.052l3.223.716A1.5 1.5 0 0118 15.352V16.5a1.5 1.5 0 01-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 012.43 8.326 13.019 13.019 0 012 5V3.5z"
                        clip-rule="evenodd"></path>
                </svg>
            </a>
        </div>
    </div>
</div>

<script>
    function initSpeedDial() {
        const toggleBtn = document.getElementById("fab-toggle");
        const menu = document.getElementById("fab-menu");

        if (!toggleBtn || !menu) return;

        // Clone node trick to prevent Astro duplicate listeners
        const newToggleBtn = toggleBtn.cloneNode(true) as HTMLButtonElement;
        toggleBtn.parentNode?.replaceChild(newToggleBtn, toggleBtn);

        const newIconOpen = newToggleBtn.querySelector("#fab-icon-open");
        const newIconClose = newToggleBtn.querySelector("#fab-icon-close");

        let isOpen = false;

        function closeDial() {
            isOpen = false;
            // Hide the menu items
            menu.classList.remove(
                "translate-y-0",
                "opacity-100",
                "pointer-events-auto",
            );
            menu.classList.add(
                "translate-y-4",
                "opacity-0",
                "pointer-events-none",
            );

            if (newIconOpen && newIconClose) {
                // Animate Chat Icon back in
                newIconOpen.classList.remove(
                    "rotate-90",
                    "scale-50",
                    "opacity-0",
                );
                newIconOpen.classList.add(
                    "rotate-0",
                    "scale-100",
                    "opacity-100",
                );

                // Animate X icon out
                newIconClose.classList.remove(
                    "rotate-0",
                    "scale-100",
                    "opacity-100",
                );
                newIconClose.classList.add(
                    "-rotate-90",
                    "scale-50",
                    "opacity-0",
                );
            }
        }

        newToggleBtn.addEventListener("click", (e) => {
            e.stopPropagation(); // prevent document click from firing immediately
            isOpen = !isOpen;

            if (isOpen) {
                // Show the menu items
                menu.classList.remove(
                    "translate-y-4",
                    "opacity-0",
                    "pointer-events-none",
                );
                menu.classList.add(
                    "translate-y-0",
                    "opacity-100",
                    "pointer-events-auto",
                );

                if (newIconOpen && newIconClose) {
                    // Animate Chat Icon out
                    newIconOpen.classList.remove(
                        "rotate-0",
                        "scale-100",
                        "opacity-100",
                    );
                    newIconOpen.classList.add(
                        "rotate-90",
                        "scale-50",
                        "opacity-0",
                    );

                    // Animate X icon in
                    newIconClose.classList.remove(
                        "-rotate-90",
                        "scale-50",
                        "opacity-0",
                    );
                    newIconClose.classList.add(
                        "rotate-0",
                        "scale-100",
                        "opacity-100",
                    );
                }
            } else {
                closeDial();
            }
        });

        // Close the dial if the user clicks anywhere else on the page
        document.addEventListener("click", (e) => {
            if (isOpen && !menu.contains(e.target as Node)) {
                closeDial();
            }
        });
    }

    // Initialize resiliently
    initSpeedDial();
    document.addEventListener("astro:page-load", initSpeedDial);
</script>
