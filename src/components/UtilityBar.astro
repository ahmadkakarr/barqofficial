---
// src/components/UtilityBar.astro
---

<nav class="hidden lg:block w-full border-b border-base-300 bg-base-100">
    <div
        class="max-w-[1440px] mx-auto px-4 lg:px-8 flex justify-between items-center h-10 text-[13px]"
    >
        <ul class="flex items-center h-full divide-x divide-base-300">
            <li class="pr-4 flex items-center h-full">
                <a href="#" class="font-bold text-primary hover:underline"
                    >Personal</a
                >
            </li>
            <li class="pl-4 flex items-center h-full">
                <a href="#" class="text-base-content/80 hover:underline"
                    >Business</a
                >
            </li>
        </ul>

        <ul
            class="flex items-center h-full divide-x divide-base-300 text-base-content/80"
        >
            <li class="px-3 flex items-center h-full">
                <a href="#" class="hover:underline">1-833-VERIZON</a>
            </li>
            <li class="px-3 flex items-center h-full">
                <a href="#" class="hover:underline">Contact us</a>
            </li>
            <li class="px-3 flex items-center h-full">
                <a href="#" class="hover:underline">Support</a>
            </li>
            <li class="px-3 flex items-center h-full">
                <a href="#" class="hover:underline">Stores</a>
            </li>
            <li class="px-3 flex items-center h-full">
                <a href="#" class="hover:underline">Coverage map</a>
            </li>
            <li class="px-3 flex items-center h-full">
                <a href="#" class="hover:underline">Español</a>
            </li>
            <li class="pl-3 flex items-center h-full">
                <button
                    id="theme-toggle"
                    class="btn btn-ghost btn-xs btn-square"
                    aria-label="Toggle theme"
                >
                    <svg
                        id="theme-toggle-light-icon"
                        class="hidden w-4 h-4"
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
                        ></path>
                    </svg>
                    <svg
                        id="theme-toggle-dark-icon"
                        class="hidden w-4 h-4"
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
                        ></path>
                    </svg>
                </button>
            </li>
        </ul>
    </div>
</nav>

<script>
    // Astro will bundle this cleanly
    const themeToggleBtn = document.getElementById("theme-toggle");
    const darkIcon = document.getElementById("theme-toggle-dark-icon");
    const lightIcon = document.getElementById("theme-toggle-light-icon");

    // Toggle icons based on current theme
    function updateIcons() {
        if (
            document.documentElement.getAttribute("data-theme") ===
            "brandtheme-dark"
        ) {
            lightIcon?.classList.remove("hidden");
            darkIcon?.classList.add("hidden");
        } else {
            darkIcon?.classList.remove("hidden");
            lightIcon?.classList.add("hidden");
        }
    }

    // Set correct icon initially
    updateIcons();

    // Handle toggle click
    themeToggleBtn?.addEventListener("click", () => {
        const currentTheme =
            document.documentElement.getAttribute("data-theme");
        const newTheme =
            currentTheme === "brandtheme-dark"
                ? "brandtheme"
                : "brandtheme-dark";

        // Update DOM and Local Storage
        document.documentElement.setAttribute("data-theme", newTheme);
        localStorage.setItem("theme", newTheme);
        updateIcons();
    });
</script>
