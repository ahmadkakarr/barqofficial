---
import "../styles/global.css";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import BookNowModal from "../components/BookNowModal.astro";
import FloatingContact from "../components/FloatingContact.astro";
// 1. Import ClientRouter for Astro 5/6 View Transitions
import { ClientRouter } from "astro:transitions";

const defaultTitle = "Barq Telecommunication Pvt Ltd.";
const defaultDescription =
    "Barq Telecommunication - Connecting you to the future.";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />

        <title>{defaultTitle}</title>
        <meta name="description" content={defaultDescription} />

        <link rel="icon" href="/images/favicon/favicon.ico" sizes="any" />
        <link
            rel="icon"
            type="image/svg+xml"
            href="/images/favicon/favicon.svg"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="96x96"
            href="/images/favicon/favicon-96x96.png"
        />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/images/favicon/apple-touch-icon.png"
        />
        <link rel="manifest" href="/images/favicon/site.webmanifest" />

        <meta property="og:title" content={defaultTitle} />
        <meta property="og:description" content={defaultDescription} />
        <meta property="og:type" content="website" />
        <meta property="og:image" content="/images/og-image.webp" />

        <ClientRouter />

        <script is:inline>
            // 5. Encapsulate theme logic to run on initial load AND after page swaps
            const applyTheme = () => {
                const getTheme = () => {
                    if (
                        typeof localStorage !== "undefined" &&
                        localStorage.getItem("theme")
                    ) {
                        return localStorage.getItem("theme");
                    }
                    if (
                        window.matchMedia("(prefers-color-scheme: dark)")
                            .matches
                    ) {
                        return "brandtheme-dark";
                    }
                    return "brandtheme";
                };
                document.documentElement.setAttribute("data-theme", getTheme());
            };

            // Run immediately on first load
            applyTheme();

            // Run after every View Transition to prevent flickering
            document.addEventListener("astro:after-swap", applyTheme);
        </script>
    </head>
    <body
        class="min-h-screen bg-base-100 text-base-content antialiased flex flex-col"
    >
        <Navigation>
            <main class="flex-grow">
                <slot />
            </main>
        </Navigation>

        <Footer />
        <BookNowModal />
        <FloatingContact />
    </body>
</html>
