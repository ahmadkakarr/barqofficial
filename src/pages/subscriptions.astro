---
import Layout from "../layouts/Layout.astro";

// --- Mock Data ---
const categories = [
    { id: "best-offers", label: "Best Offers", active: true },
    { id: "monthly", label: "Monthly", active: false },
    { id: "quarterly", label: "Quarterly", active: false },
    { id: "semi-annual", label: "Semi-Annual", active: false },
    { id: "annual", label: "Annual", active: false },
];

const planGroups = [
    {
        id: "tier-20",
        title: "20 Mbps",
        isOpen: false,
        plans: [
            {
                name: "Essential",
                price: "3,500",
                validity: "1 Month",
                speed: "Upto 20 Mbps",
                features: ["Internet Only"],
            },
            {
                name: "Media Plus",
                price: "4,000",
                validity: "1 Month",
                speed: "Upto 20 Mbps",
                features: ["Internet", "Live TV"],
            },
        ],
    },
    {
        id: "tier-30",
        title: "30 Mbps (Best Seller)",
        isOpen: true, // Open by default
        plans: [
            {
                name: "Essential Monthly",
                price: "4,500",
                validity: "1 Month",
                speed: "Upto 30 Mbps",
                features: ["Internet Only"],
            },
            {
                name: "Media Plus Monthly",
                price: "5,000",
                validity: "1 Month",
                speed: "Upto 30 Mbps",
                features: ["Internet", "TV App"],
            },
            {
                name: "Pro Connect Monthly",
                price: "6,000",
                validity: "1 Month",
                speed: "Upto 30 Mbps",
                features: ["Internet", "TV", "Static IP"],
            },
            {
                name: "Gamer Elite Monthly",
                price: "5,500",
                validity: "1 Month",
                speed: "Upto 30 Mbps",
                features: ["Low Latency", "Gaming Routing"],
            },
            {
                name: "Essential Quarterly",
                price: "18,000",
                validity: "4 Months", // As requested, Quarterly = 4 months
                speed: "Upto 30 Mbps",
                features: ["Internet Only"],
            },
            {
                name: "Pro Connect Quarterly",
                price: "24,000",
                validity: "4 Months",
                speed: "Upto 30 Mbps",
                features: ["Internet", "TV", "Static IP"],
            },
        ],
    },
    {
        id: "tier-40",
        title: "40 Mbps",
        isOpen: false,
        plans: [
            {
                name: "Essential",
                price: "5,500",
                validity: "1 Month",
                speed: "Upto 40 Mbps",
                features: ["Internet Only"],
            },
            {
                name: "Pro Connect",
                price: "7,000",
                validity: "1 Month",
                speed: "Upto 40 Mbps",
                features: ["Internet", "TV", "Static IP"],
            },
        ],
    },
    {
        id: "tier-50",
        title: "50 Mbps",
        isOpen: false,
        plans: [
            {
                name: "Essential",
                price: "6,500",
                validity: "1 Month",
                speed: "Upto 50 Mbps",
                features: ["Internet Only"],
            },
            {
                name: "Gamer Elite",
                price: "7,500",
                validity: "1 Month",
                speed: "Upto 50 Mbps",
                features: ["Low Latency", "Gaming Routing"],
            },
        ],
    },
    {
        id: "tier-100",
        title: "100 Mbps",
        isOpen: false,
        plans: [
            {
                name: "Essential",
                price: "15,000",
                validity: "1 Month",
                speed: "Upto 100 Mbps",
                features: ["Internet Only"],
            },
            {
                name: "Enterprise Ultimate",
                price: "17,500",
                validity: "1 Month",
                speed: "Upto 100 Mbps",
                features: ["4K Streaming", "Static IP", "Priority Support"],
            },
        ],
    },
];
---

<Layout title="Subscription Packages">
    <div
        class="max-w-[1440px] mx-auto min-h-screen bg-base-100 relative flex flex-col lg:flex-row pb-16"
    >
        <div
            class="sticky top-0 z-40 bg-base-100/95 backdrop-blur-sm border-b border-base-300 p-4 lg:hidden"
        >
            <nav
                class="flex overflow-x-auto gap-3 pb-1 hide-scrollbar"
                aria-label="Plan Categories Mobile"
            >
                {
                    categories.map((cat) => (
                        <button
                            data-category={cat.id}
                            class={`category-filter mobile-filter btn btn-sm rounded-full whitespace-nowrap border-none transition-colors
                        ${cat.active ? "btn-primary text-primary-content shadow-md" : "bg-base-200 text-base-content hover:bg-base-300"}`}
                        >
                            {cat.label}
                        </button>
                    ))
                }
            </nav>
        </div>

        <aside
            class="hidden lg:block w-[250px] shrink-0 sticky top-8 h-fit p-6 border-r border-base-200 mr-4"
        >
            <h2
                class="text-xs font-bold text-base-content/50 uppercase tracking-wider mb-4 px-4"
            >
                Categories
            </h2>
            <ul
                class="menu bg-base-100 rounded-box p-0 gap-1"
                aria-label="Plan Categories Desktop"
            >
                {
                    categories.map((cat) => (
                        <li>
                            <a
                                href={`#${cat.id}`}
                                data-category={cat.id}
                                class={`category-filter desktop-filter rounded-xl py-3 transition-colors ${
                                    cat.active
                                        ? "active bg-primary text-primary-content shadow-sm font-medium"
                                        : "hover:bg-base-200 text-base-content/80"
                                }`}
                            >
                                {cat.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </aside>

        <main class="flex-1 p-4 lg:p-8 lg:pt-8 w-full">
            <header class="mb-8 hidden lg:block">
                <h1
                    class="text-3xl font-bold text-base-content flex items-center gap-3"
                >
                    Subscription Packages
                </h1>
                <div class="flex items-center gap-3 mt-2">
                    <p class="text-base-content/60">
                        Choose the perfect high-speed plan for your needs.
                    </p>
                    <span
                        class="badge badge-neutral text-xs font-semibold py-3 px-3 shadow-sm"
                    >
                        One time installation charges: Rs. 4,000
                    </span>
                </div>
            </header>

            <div class="space-y-6">
                {
                    planGroups.map((group) => (
                        <details
                            class="plan-group collapse collapse-arrow bg-base-100 border border-base-200 rounded-2xl shadow-sm"
                            open={group.isOpen}
                        >
                            <summary class="collapse-title text-xl font-semibold bg-base-100/50 hover:bg-base-200/50 transition-colors">
                                {group.title}
                                <span class="plan-count text-base-content/50 text-sm font-normal ml-2">
                                    ({group.plans.length}{" "}
                                    {group.plans.length === 1
                                        ? "plan"
                                        : "plans"}
                                    )
                                </span>
                            </summary>

                            <div class="collapse-content border-t border-base-200 bg-base-100">
                                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 pt-6">
                                    {group.plans.map((plan) => {
                                        // Infer category based on Validity text from mock data
                                        const validityLower =
                                            plan.validity.toLowerCase();
                                        const planCategory =
                                            validityLower.includes("1 month")
                                                ? "monthly"
                                                : validityLower.includes(
                                                        "4 month",
                                                    ) ||
                                                    validityLower.includes(
                                                        "3 month",
                                                    )
                                                  ? "quarterly"
                                                  : validityLower.includes(
                                                          "6 month",
                                                      )
                                                    ? "semi-annual"
                                                    : validityLower.includes(
                                                            "12 month",
                                                        ) ||
                                                        validityLower.includes(
                                                            "1 year",
                                                        )
                                                      ? "annual"
                                                      : "best-offers";

                                        return (
                                            <article
                                                class="plan-card card bg-base-200 rounded-2xl border border-base-300/40 transition-all duration-300 hover:shadow-[0_8px_30px_rgb(0,0,0,0.08)] hover:-translate-y-1"
                                                data-category={planCategory}
                                            >
                                                <div class="card-body p-6 flex flex-col h-full gap-4">
                                                    <div>
                                                        <h3 class="text-lg font-semibold text-base-content/70 mb-1">
                                                            {plan.name}
                                                        </h3>
                                                        <div class="flex items-end gap-1">
                                                            <span class="text-3xl font-bold text-base-content tracking-tight">
                                                                Rs. {plan.price}
                                                            </span>
                                                        </div>
                                                    </div>

                                                    <div class="flex justify-between items-center py-4 border-y border-base-300/50 mt-2">
                                                        <div class="flex flex-col">
                                                            <span class="text-[11px] text-base-content/50 uppercase tracking-widest font-bold mb-1">
                                                                Validity
                                                            </span>
                                                            <span class="text-sm font-semibold text-base-content">
                                                                {plan.validity}
                                                            </span>
                                                        </div>
                                                        <div class="w-px h-8 bg-base-300/80" />
                                                        <div class="flex flex-col text-right">
                                                            <span class="text-[11px] text-base-content/50 uppercase tracking-widest font-bold mb-1">
                                                                Speed
                                                            </span>
                                                            <span class="text-sm font-semibold text-base-content">
                                                                {plan.speed}
                                                            </span>
                                                        </div>
                                                    </div>

                                                    <div class="flex flex-col mt-2 min-h-[3rem]">
                                                        <div class="text-xs font-semibold text-base-content/60 mb-2">
                                                            Highlights:
                                                        </div>
                                                        <div class="flex flex-wrap gap-2">
                                                            {plan.features.map(
                                                                (feature) => (
                                                                    <span class="badge badge-sm badge-outline badge-primary font-medium">
                                                                        {
                                                                            feature
                                                                        }
                                                                    </span>
                                                                ),
                                                            )}
                                                        </div>
                                                    </div>

                                                    <div class="mt-auto pt-5 w-full">
                                                        <button class="btn btn-primary btn-block rounded-full font-bold shadow-md shadow-primary/20 hover:shadow-primary/40">
                                                            Book Now
                                                        </button>
                                                    </div>
                                                </div>
                                            </article>
                                        );
                                    })}
                                </div>
                            </div>
                        </details>
                    ))
                }
            </div>
        </main>
    </div>
</Layout>

<style>
    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    details > summary {
        list-style: none;
    }
    details > summary::-webkit-details-marker {
        display: none;
    }
</style>

<script>
    // Filtering Logic mapped to Data Attributes generated in the markup
    function initFilters() {
        const filters = document.querySelectorAll(".category-filter");
        const planGroups = document.querySelectorAll(".plan-group");

        filters.forEach((filter) => {
            filter.addEventListener("click", (e) => {
                e.preventDefault();
                const targetCategory = filter.getAttribute("data-category");

                // 1. Update filter button styling (active states for Desktop and Mobile)
                filters.forEach((btn) => {
                    const isMobile = btn.classList.contains("mobile-filter");
                    const isActive =
                        btn.getAttribute("data-category") === targetCategory;

                    if (isMobile) {
                        if (isActive) {
                            btn.classList.add(
                                "btn-primary",
                                "text-primary-content",
                                "shadow-md",
                            );
                            btn.classList.remove(
                                "bg-base-200",
                                "text-base-content",
                                "hover:bg-base-300",
                            );
                        } else {
                            btn.classList.remove(
                                "btn-primary",
                                "text-primary-content",
                                "shadow-md",
                            );
                            btn.classList.add(
                                "bg-base-200",
                                "text-base-content",
                                "hover:bg-base-300",
                            );
                        }
                    } else {
                        if (isActive) {
                            btn.classList.add(
                                "active",
                                "bg-primary",
                                "text-primary-content",
                                "shadow-sm",
                                "font-medium",
                            );
                            btn.classList.remove(
                                "hover:bg-base-200",
                                "text-base-content/80",
                            );
                        } else {
                            btn.classList.remove(
                                "active",
                                "bg-primary",
                                "text-primary-content",
                                "shadow-sm",
                                "font-medium",
                            );
                            btn.classList.add(
                                "hover:bg-base-200",
                                "text-base-content/80",
                            );
                        }
                    }
                });

                // 2. Filter the plans based on category
                planGroups.forEach((group) => {
                    let visibleCount = 0;
                    const cards = group.querySelectorAll(".plan-card");

                    cards.forEach((card) => {
                        const cardCategory = card.getAttribute("data-category");

                        // "best-offers" will act as a "View All" filter
                        if (
                            targetCategory === "best-offers" ||
                            cardCategory === targetCategory
                        ) {
                            card.style.display = ""; // Reset to default flex
                            visibleCount++;
                        } else {
                            card.style.display = "none";
                        }
                    });

                    // 3. Update the item count badge and Collapse section visibility
                    const countSpan = group.querySelector(".plan-count");
                    if (countSpan) {
                        countSpan.textContent = `(${visibleCount} ${visibleCount === 1 ? "plan" : "plans"})`;
                    }

                    // Hide the entire tier accordion if it has no visible items for that filter
                    if (visibleCount === 0) {
                        group.style.display = "none";
                    } else {
                        group.style.display = "";
                    }
                });
            });
        });
    }

    initFilters();
</script>
