---
import Layout from "../layouts/Layout.astro"; // Adjust path if necessary

// --- Mock Data ---
const categories = [
    { id: "best-offers", label: "Best Offers", active: true },
    { id: "monthly", label: "Monthly", active: false },
    { id: "quarterly", label: "Quarterly", active: false },
    { id: "semi-annual", label: "Semi-Annual", active: false },
    { id: "annual", label: "Annual", active: false },
];

const planGroups = [
    {
        id: "tier-30",
        title: "30 Mbps",
        isOpen: true, // First one open by default
        plans: [
            {
                name: "Starter",
                price: "1,500",
                validity: "1 Month",
                speed: "Upto 30 Mbps",
                ottCount: 2,
            },
            {
                name: "Starter Plus",
                price: "4,000",
                validity: "3 Months",
                speed: "Upto 30 Mbps",
                ottCount: 4,
            },
            {
                name: "Starter Pro",
                price: "15,000",
                validity: "12 Months",
                speed: "Upto 30 Mbps",
                ottCount: 6,
            },
        ],
    },
    {
        id: "tier-100",
        title: "100 Mbps",
        isOpen: false, // Closed by default
        plans: [
            {
                name: "Streamer",
                price: "3,500",
                validity: "1 Month",
                speed: "Upto 100 Mbps",
                ottCount: 3,
            },
            {
                name: "Streamer Pro",
                price: "35,000",
                validity: "12 Months",
                speed: "Upto 100 Mbps",
                ottCount: 12,
            },
        ],
    },
];
---

<Layout title="Subscription Packages">
    <div
        class="max-w-[1440px] mx-auto min-h-screen bg-base-100 relative flex flex-col lg:flex-row pb-16"
    >
        <div
            class="sticky top-0 z-40 bg-base-100/95 backdrop-blur-sm border-b border-base-300 p-4 lg:hidden"
        >
            <nav
                class="flex overflow-x-auto gap-3 pb-1 hide-scrollbar"
                aria-label="Plan Categories Mobile"
            >
                {
                    categories.map((cat) => (
                        <button
                            class={`btn btn-sm rounded-full whitespace-nowrap border-none transition-colors
                        ${cat.active ? "btn-primary text-primary-content shadow-md" : "bg-base-200 text-base-content hover:bg-base-300"}`}
                        >
                            {cat.label}
                        </button>
                    ))
                }
            </nav>
        </div>

        <aside
            class="hidden lg:block w-[250px] shrink-0 sticky top-8 h-fit p-6 border-r border-base-200 mr-4"
        >
            <h2
                class="text-xs font-bold text-base-content/50 uppercase tracking-wider mb-4 px-4"
            >
                Categories
            </h2>
            <ul
                class="menu bg-base-100 rounded-box p-0 gap-1"
                aria-label="Plan Categories Desktop"
            >
                {
                    categories.map((cat) => (
                        <li>
                            <a
                                href={`#${cat.id}`}
                                class={`rounded-xl py-3 transition-colors ${cat.active ? "active bg-primary text-primary-content shadow-sm font-medium" : "hover:bg-base-200 text-base-content/80"}`}
                            >
                                {cat.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </aside>

        <main class="flex-1 p-4 lg:p-8 lg:pt-8 w-full">
            <header class="mb-8 hidden lg:block">
                <h1 class="text-3xl font-bold text-base-content">
                    Subscription Packages
                </h1>
                <p class="text-base-content/60 mt-1">
                    Choose the perfect high-speed plan for your needs.
                </p>
            </header>

            <div class="space-y-6">
                {
                    planGroups.map((group) => (
                        // DaisyUI Native Accordion using <details> tag
                        <details
                            class="collapse collapse-arrow bg-base-100 border border-base-200 rounded-2xl shadow-sm"
                            open={group.isOpen}
                        >
                            <summary class="collapse-title text-xl font-semibold bg-base-100/50 hover:bg-base-200/50 transition-colors">
                                {group.title}
                                <span class="text-base-content/50 text-sm font-normal ml-2">
                                    ({group.plans.length}{" "}
                                    {group.plans.length === 1
                                        ? "plan"
                                        : "plans"}
                                    )
                                </span>
                            </summary>

                            <div class="collapse-content border-t border-base-200 bg-base-100">
                                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 pt-6">
                                    {group.plans.map((plan) => (
                                        // Individual Plan Card
                                        <article class="card bg-base-200 rounded-2xl border border-base-300/40 transition-all duration-300 hover:shadow-[0_8px_30px_rgb(0,0,0,0.08)] hover:-translate-y-1">
                                            <div class="card-body p-6 flex flex-col h-full gap-4">
                                                <div>
                                                    <h3 class="text-lg font-semibold text-base-content/70 mb-1">
                                                        {plan.name}
                                                    </h3>
                                                    <div class="flex items-end gap-1">
                                                        <span class="text-3xl font-bold text-base-content tracking-tight">
                                                            Rs. {plan.price}
                                                        </span>
                                                        <span class="text-sm text-base-content/60 font-medium mb-1">
                                                            +GST
                                                        </span>
                                                    </div>
                                                </div>

                                                <div class="flex justify-between items-center py-4 border-y border-base-300/50 mt-2">
                                                    <div class="flex flex-col">
                                                        <span class="text-[11px] text-base-content/50 uppercase tracking-widest font-bold mb-1">
                                                            Validity
                                                        </span>
                                                        <span class="text-sm font-semibold text-base-content">
                                                            {plan.validity}
                                                        </span>
                                                    </div>
                                                    <div class="w-px h-8 bg-base-300/80" />
                                                    <div class="flex flex-col text-right">
                                                        <span class="text-[11px] text-base-content/50 uppercase tracking-widest font-bold mb-1">
                                                            Speed
                                                        </span>
                                                        <span class="text-sm font-semibold text-base-content">
                                                            {plan.speed}
                                                        </span>
                                                    </div>
                                                </div>

                                                <div class="flex items-center justify-between mt-2 h-8">
                                                    <div class="text-xs font-semibold text-base-content/60">
                                                        Includes OTT:
                                                    </div>
                                                    <div class="flex items-center gap-2">
                                                        <div class="avatar-group -space-x-3 rtl:space-x-reverse border-none">
                                                            <div class="avatar border-2 border-base-200">
                                                                <div class="w-7 bg-red-600 rounded-full flex items-center justify-center text-[10px] text-white font-bold">
                                                                    N
                                                                </div>
                                                            </div>
                                                            <div class="avatar border-2 border-base-200">
                                                                <div class="w-7 bg-blue-500 rounded-full flex items-center justify-center text-[10px] text-white font-bold">
                                                                    P
                                                                </div>
                                                            </div>
                                                        </div>
                                                        {plan.ottCount > 2 && (
                                                            <span class="text-xs text-base-content/60 font-medium ml-1">
                                                                +
                                                                {plan.ottCount -
                                                                    2}{" "}
                                                                more
                                                            </span>
                                                        )}
                                                    </div>
                                                </div>

                                                <div class="mt-auto pt-5 w-full">
                                                    <button class="btn btn-primary btn-block rounded-full font-bold shadow-md shadow-primary/20 hover:shadow-primary/40">
                                                        Book Now
                                                    </button>
                                                </div>
                                            </div>
                                        </article>
                                    ))}
                                </div>
                            </div>
                        </details>
                    ))
                }
            </div>
        </main>
    </div>
</Layout>

<style>
    /* Utility class to hide scrollbar on the mobile horizontal nav while keeping it scrollable */
    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    /* Ensure Details/Summary removes default browser arrow markers */
    details > summary {
        list-style: none;
    }
    details > summary::-webkit-details-marker {
        display: none;
    }
</style>
