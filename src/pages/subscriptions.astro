---
import Layout from "../layouts/Layout.astro";

// --- Mock Data ---
const planGroups = [
    {
        id: "tier-20",
        title: "20 Mbps",
        isOpen: false,
        plans: [
            {
                name: "Essential",
                price: "3,500",
                validity: "1 Month",
                speed: "Upto 20 Mbps",
                features: ["Internet Only"],
            },
            {
                name: "Media Plus",
                price: "4,000",
                validity: "1 Month",
                speed: "Upto 20 Mbps",
                features: ["Internet", "Live TV"],
            },
        ],
    },
    {
        id: "tier-30",
        title: "30 Mbps (Best Seller)",
        isOpen: true,
        plans: [
            {
                name: "Essential Monthly",
                price: "4,500",
                validity: "1 Month",
                speed: "Upto 30 Mbps",
                features: ["Internet Only"],
            },
            {
                name: "Media Plus Monthly",
                price: "5,000",
                validity: "1 Month",
                speed: "Upto 30 Mbps",
                features: ["Internet", "TV App"],
            },
            {
                name: "Pro Connect Monthly",
                price: "6,000",
                validity: "1 Month",
                speed: "Upto 30 Mbps",
                features: ["Internet", "TV", "Static IP"],
            },
            {
                name: "Gamer Elite Monthly",
                price: "5,500",
                validity: "1 Month",
                speed: "Upto 30 Mbps",
                features: ["Low Latency", "Gaming Routing"],
            },
            {
                name: "Essential Quarterly",
                price: "18,000",
                validity: "4 Months",
                speed: "Upto 30 Mbps",
                features: ["Internet Only"],
            },
            {
                name: "Pro Connect Quarterly",
                price: "24,000",
                validity: "4 Months",
                speed: "Upto 30 Mbps",
                features: ["Internet", "TV", "Static IP"],
            },
        ],
    },
    {
        id: "tier-40",
        title: "40 Mbps",
        isOpen: false,
        plans: [
            {
                name: "Essential",
                price: "5,500",
                validity: "1 Month",
                speed: "Upto 40 Mbps",
                features: ["Internet Only"],
            },
            {
                name: "Pro Connect",
                price: "7,000",
                validity: "1 Month",
                speed: "Upto 40 Mbps",
                features: ["Internet", "TV", "Static IP"],
            },
        ],
    },
    {
        id: "tier-50",
        title: "50 Mbps",
        isOpen: false,
        plans: [
            {
                name: "Essential",
                price: "6,500",
                validity: "1 Month",
                speed: "Upto 50 Mbps",
                features: ["Internet Only"],
            },
            {
                name: "Gamer Elite",
                price: "7,500",
                validity: "1 Month",
                speed: "Upto 50 Mbps",
                features: ["Low Latency", "Gaming Routing"],
            },
        ],
    },
    {
        id: "tier-100",
        title: "100 Mbps",
        isOpen: false,
        plans: [
            {
                name: "Essential",
                price: "15,000",
                validity: "1 Month",
                speed: "Upto 100 Mbps",
                features: ["Internet Only"],
            },
            {
                name: "Enterprise Ultimate",
                price: "17,500",
                validity: "1 Month",
                speed: "Upto 100 Mbps",
                features: ["4K Streaming", "Static IP", "Priority Support"],
            },
        ],
    },
];
---

<Layout title="Subscription Packages">
    <div
        class="max-w-[1440px] mx-auto min-h-screen bg-base-100 pb-24 pt-8 px-4 lg:px-8"
    >
        <header
            class="mb-8 text-center lg:text-left border-b border-base-200 pb-8"
        >
            <h1
                class="text-3xl lg:text-4xl font-black text-base-content tracking-tight"
            >
                Subscription Packages
            </h1>
            <div
                class="flex flex-col lg:flex-row lg:items-center justify-between mt-4 gap-4"
            >
                <p class="text-base-content/70 text-lg">
                    Choose the perfect high-speed plan for your needs.
                </p>
                <span
                    class="badge badge-neutral badge-lg py-4 px-4 shadow-sm shrink-0 font-bold text-xs uppercase tracking-wider"
                >
                    Installation: Rs. 4,000
                </span>
            </div>
        </header>

        <div class="flex flex-col lg:flex-row gap-8 items-start">
            <aside
                class="w-full lg:w-[280px] xl:w-[320px] shrink-0 lg:sticky lg:top-24 z-20"
            >
                <div
                    class="bg-base-200/50 rounded-2xl border border-base-300 shadow-sm overflow-hidden"
                >
                    <button
                        id="mobile-filter-toggle"
                        class="w-full flex lg:hidden items-center justify-between p-4 bg-base-200 hover:bg-base-300 transition-colors"
                    >
                        <span
                            class="text-sm font-bold uppercase tracking-widest text-primary flex items-center gap-2"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-5 h-5"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><polygon
                                    points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"
                                ></polygon></svg
                            >
                            Filter Packages
                        </span>
                        <svg
                            id="filter-chevron"
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-5 h-5 transition-transform text-base-content/50"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><polyline points="6 9 12 15 18 9"></polyline></svg
                        >
                    </button>

                    <div
                        id="filter-container"
                        class="hidden lg:flex flex-col gap-8 p-5 lg:p-6 border-t border-base-300 lg:border-t-0"
                    >
                        <div class="flex flex-col gap-3">
                            <span
                                class="text-xs font-bold uppercase tracking-widest text-base-content/50"
                                >Billing Cycle</span
                            >
                            <div class="flex flex-wrap lg:flex-col gap-2">
                                <button
                                    class="filter-btn btn btn-sm lg:btn-md rounded-full lg:rounded-xl lg:justify-start lg:px-4 btn-primary shadow-md"
                                    data-type="validity"
                                    data-val="all">All Cycles</button
                                >
                                <button
                                    class="filter-btn btn btn-sm lg:btn-md rounded-full lg:rounded-xl lg:justify-start lg:px-4 btn-outline btn-primary"
                                    data-type="validity"
                                    data-val="monthly">Monthly</button
                                >
                                <button
                                    class="filter-btn btn btn-sm lg:btn-md rounded-full lg:rounded-xl lg:justify-start lg:px-4 btn-outline btn-primary"
                                    data-type="validity"
                                    data-val="quarterly">Quarterly</button
                                >
                                <button
                                    class="filter-btn btn btn-sm lg:btn-md rounded-full lg:rounded-xl lg:justify-start lg:px-4 btn-outline btn-primary"
                                    data-type="validity"
                                    data-val="semi-annual">Half Yearly</button
                                >
                                <button
                                    class="filter-btn btn btn-sm lg:btn-md rounded-full lg:rounded-xl lg:justify-start lg:px-4 btn-outline btn-primary"
                                    data-type="validity"
                                    data-val="annual">Yearly</button
                                >
                            </div>
                        </div>

                        <div class="flex flex-col gap-3">
                            <span
                                class="text-xs font-bold uppercase tracking-widest text-base-content/50"
                                >Speed (Mbps)</span
                            >
                            <div
                                class="flex flex-wrap lg:grid lg:grid-cols-2 gap-2"
                            >
                                <button
                                    class="filter-btn btn btn-sm lg:btn-md rounded-full lg:rounded-xl btn-primary shadow-md"
                                    data-type="speed"
                                    data-val="all">All</button
                                >
                                <button
                                    class="filter-btn btn btn-sm lg:btn-md rounded-full lg:rounded-xl btn-outline btn-primary"
                                    data-type="speed"
                                    data-val="20">20</button
                                >
                                <button
                                    class="filter-btn btn btn-sm lg:btn-md rounded-full lg:rounded-xl btn-outline btn-primary"
                                    data-type="speed"
                                    data-val="30">30</button
                                >
                                <button
                                    class="filter-btn btn btn-sm lg:btn-md rounded-full lg:rounded-xl btn-outline btn-primary"
                                    data-type="speed"
                                    data-val="40">40</button
                                >
                                <button
                                    class="filter-btn btn btn-sm lg:btn-md rounded-full lg:rounded-xl btn-outline btn-primary"
                                    data-type="speed"
                                    data-val="50">50</button
                                >
                                <button
                                    class="filter-btn btn btn-sm lg:btn-md rounded-full lg:rounded-xl btn-outline btn-primary"
                                    data-type="speed"
                                    data-val="100">100</button
                                >
                            </div>
                        </div>
                    </div>
                </div>
            </aside>

            <main class="flex-1 space-y-6 relative min-h-[400px] w-full">
                {
                    planGroups.map((group) => (
                        <details
                            class="plan-group collapse collapse-arrow bg-base-100 border border-base-200 rounded-3xl shadow-sm transition-all duration-300"
                            open={group.isOpen}
                        >
                            <summary class="collapse-title text-xl font-bold bg-base-100 hover:bg-base-200/50 transition-colors py-5 px-6">
                                {group.title}
                                <span class="plan-count text-base-content/50 text-sm font-normal ml-2">
                                    ({group.plans.length}{" "}
                                    {group.plans.length === 1
                                        ? "plan"
                                        : "plans"}
                                    )
                                </span>
                            </summary>

                            <div class="collapse-content border-t border-base-200 bg-base-100/50 px-6">
                                <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 pt-6 pb-2">
                                    {group.plans.map((plan) => {
                                        const v = plan.validity.toLowerCase();
                                        let planValidity = "all";
                                        if (v.includes("1 month"))
                                            planValidity = "monthly";
                                        else if (
                                            v.includes("3 month") ||
                                            v.includes("4 month")
                                        )
                                            planValidity = "quarterly";
                                        else if (v.includes("6 month"))
                                            planValidity = "semi-annual";
                                        else if (
                                            v.includes("12 month") ||
                                            v.includes("1 year")
                                        )
                                            planValidity = "annual";

                                        const planSpeed = plan.speed.replace(
                                            /\D/g,
                                            "",
                                        );

                                        return (
                                            <article
                                                class="plan-card card bg-base-100 rounded-2xl border border-base-300/60 shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
                                                data-validity={planValidity}
                                                data-speed={planSpeed}
                                            >
                                                <div class="card-body p-6 flex flex-col h-full gap-4">
                                                    <div>
                                                        <h3 class="text-lg font-bold text-base-content/80 mb-1">
                                                            {plan.name}
                                                        </h3>
                                                        <div class="flex items-end gap-1">
                                                            <span class="text-3xl font-black text-primary tracking-tight">
                                                                Rs. {plan.price}
                                                            </span>
                                                        </div>
                                                    </div>

                                                    <div class="flex justify-between items-center py-4 border-y border-base-300/50 mt-2 bg-base-200/30 rounded-xl px-4">
                                                        <div class="flex flex-col">
                                                            <span class="text-[10px] text-base-content/50 uppercase tracking-widest font-bold mb-1">
                                                                Validity
                                                            </span>
                                                            <span class="text-sm font-bold text-base-content">
                                                                {plan.validity}
                                                            </span>
                                                        </div>
                                                        <div class="w-px h-8 bg-base-300/80" />
                                                        <div class="flex flex-col text-right">
                                                            <span class="text-[10px] text-base-content/50 uppercase tracking-widest font-bold mb-1">
                                                                Speed
                                                            </span>
                                                            <span class="text-sm font-bold text-base-content">
                                                                {plan.speed}
                                                            </span>
                                                        </div>
                                                    </div>

                                                    <div class="flex flex-col mt-2 min-h-[3rem]">
                                                        <div class="text-xs font-bold text-base-content/50 mb-2 uppercase tracking-wider">
                                                            Highlights
                                                        </div>
                                                        <div class="flex flex-wrap gap-2">
                                                            {plan.features.map(
                                                                (feature) => (
                                                                    <span class="badge badge-sm badge-outline badge-neutral font-medium">
                                                                        {
                                                                            feature
                                                                        }
                                                                    </span>
                                                                ),
                                                            )}
                                                        </div>
                                                    </div>

                                                    <div class="mt-auto pt-5 w-full">
                                                        <button
                                                            class="btn btn-primary btn-block rounded-xl font-bold shadow-md shadow-primary/20 hover:shadow-primary/40"
                                                            onclick="document.getElementById('book_now_modal').showModal()"
                                                        >
                                                            Book Now
                                                        </button>
                                                    </div>
                                                </div>
                                            </article>
                                        );
                                    })}
                                </div>
                            </div>
                        </details>
                    ))
                }

                <div
                    id="empty-state"
                    class="hidden absolute inset-0 flex flex-col items-center justify-center py-20 text-center"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                        class="w-16 h-16 opacity-20 mb-4"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                        ></path>
                    </svg>
                    <h3 class="text-xl font-bold text-base-content/70">
                        No matching plans found.
                    </h3>
                    <p class="text-sm text-base-content/50 mt-2">
                        Try adjusting your filters to see more options.
                    </p>
                </div>
            </main>
        </div>
    </div>
</Layout>

<style>
    details > summary {
        list-style: none;
    }
    details > summary::-webkit-details-marker {
        display: none;
    }
</style>

<script>
    function initDualFilters() {
        let activeFilters = {
            validity: "all",
            speed: "all",
        };

        function applyFilters() {
            const planGroups = document.querySelectorAll(".plan-group");
            const emptyState = document.getElementById("empty-state");
            let totalVisibleCards = 0;

            // 1. Filter Grid
            planGroups.forEach((group) => {
                const g = group as HTMLElement;
                const cards = g.querySelectorAll(".plan-card");
                let groupVisibleCards = 0;

                cards.forEach((card) => {
                    const c = card as HTMLElement;
                    const cardValidity = c.getAttribute("data-validity");
                    const cardSpeed = c.getAttribute("data-speed");

                    const matchValidity =
                        activeFilters.validity === "all" ||
                        activeFilters.validity === cardValidity;
                    const matchSpeed =
                        activeFilters.speed === "all" ||
                        activeFilters.speed === cardSpeed;

                    if (matchValidity && matchSpeed) {
                        c.style.display = "";
                        groupVisibleCards++;
                        totalVisibleCards++;
                    } else {
                        c.style.display = "none";
                    }
                });

                const countSpan = g.querySelector(".plan-count");
                if (countSpan) {
                    countSpan.textContent = `(${groupVisibleCards} ${groupVisibleCards === 1 ? "plan" : "plans"})`;
                }

                g.style.display = groupVisibleCards === 0 ? "none" : "block";
            });

            if (emptyState) {
                emptyState.style.display =
                    totalVisibleCards === 0 ? "flex" : "none";
            }

            // 2. Highlight correct pills/buttons
            const liveFilterBtns = document.querySelectorAll(".filter-btn");
            liveFilterBtns.forEach((btn) => {
                const b = btn as HTMLButtonElement;
                const type = b.getAttribute("data-type");
                const val = b.getAttribute("data-val");

                if (
                    type &&
                    activeFilters[type as keyof typeof activeFilters] === val
                ) {
                    b.classList.remove("btn-outline");
                    b.classList.add("shadow-md");
                } else {
                    b.classList.add("btn-outline");
                    b.classList.remove("shadow-md");
                }
            });
        }

        // 3. Click Listeners for Buttons
        const filterBtns = document.querySelectorAll(".filter-btn");
        filterBtns.forEach((btn) => {
            if (btn.getAttribute("data-listener") === "true") return;
            btn.setAttribute("data-listener", "true");

            btn.addEventListener("click", () => {
                const type = btn.getAttribute("data-type");
                const val = btn.getAttribute("data-val");

                if (type && val) {
                    activeFilters[type as keyof typeof activeFilters] = val;
                    applyFilters();
                }
            });
        });

        // 4. Mobile UX Accordion Toggle
        const toggleBtn = document.getElementById("mobile-filter-toggle");
        const container = document.getElementById("filter-container");
        const chevron = document.getElementById("filter-chevron");

        if (toggleBtn && container && chevron) {
            if (toggleBtn.getAttribute("data-listener") !== "true") {
                toggleBtn.setAttribute("data-listener", "true");
                toggleBtn.addEventListener("click", () => {
                    container.classList.toggle("hidden");
                    container.classList.toggle("flex");
                    chevron.classList.toggle("rotate-180");
                });
            }
        }

        // Run once on load
        applyFilters();
    }

    initDualFilters();
    document.addEventListener("astro:page-load", initDualFilters);
</script>
