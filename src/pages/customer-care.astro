---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Customer Care Center - Barq">
    <div class="min-h-screen bg-base-100 pb-24 relative overflow-hidden">
        <div
            class="absolute top-0 left-0 w-full h-96 bg-gradient-to-b from-base-200 to-base-100 z-0"
        >
        </div>
        <div
            class="absolute -top-24 -right-24 w-96 h-96 bg-primary/5 rounded-full mix-blend-multiply filter blur-[80px] z-0"
        >
        </div>

        <div
            class="max-w-[1440px] mx-auto px-4 lg:px-8 relative z-10 pt-16 lg:pt-24"
        >
            <div class="text-center mb-16">
                <div
                    class="inline-flex items-center justify-center p-3 bg-primary/10 text-primary rounded-2xl mb-6"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                        class="w-8 h-8"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"
                        ></path>
                    </svg>
                </div>
                <h1
                    class="text-4xl lg:text-5xl font-black text-base-content tracking-tight mb-4"
                >
                    Customer Care <span class="text-primary">Center</span>
                </h1>
                <p class="text-lg text-base-content/70 max-w-2xl mx-auto">
                    Welcome to the Barq support hub. Choose an option below to
                    find answers, manage your connection, or get in touch with
                    our team.
                </p>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6 max-w-5xl mx-auto"
            >
                <a
                    href="/faq"
                    class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-primary/30 transition-all duration-300 group cursor-pointer"
                >
                    <div
                        class="card-body p-8 lg:p-10 flex flex-row gap-6 items-start"
                    >
                        <div
                            class="w-16 h-16 shrink-0 rounded-2xl bg-base-200 flex items-center justify-center text-base-content group-hover:bg-primary group-hover:text-primary-content transition-colors duration-300"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="w-8 h-8"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h2
                                class="text-2xl font-bold text-base-content mb-2 group-hover:text-primary transition-colors"
                            >
                                Knowledge Base & FAQ
                            </h2>
                            <p
                                class="text-base-content/70 text-sm leading-relaxed mb-4"
                            >
                                Find quick answers about our fiber and wireless
                                plans, installation timelines, and basic
                                troubleshooting.
                            </p>
                            <span
                                class="text-primary font-semibold text-sm flex items-center gap-1"
                                >Browse Articles <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    viewBox="0 0 20 20"
                                    fill="currentColor"
                                    class="w-4 h-4"
                                    ><path
                                        fill-rule="evenodd"
                                        d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                                        clip-rule="evenodd"></path></svg
                                ></span
                            >
                        </div>
                    </div>
                </a>

                <a
                    href="/contact"
                    class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-secondary/30 transition-all duration-300 group cursor-pointer"
                >
                    <div
                        class="card-body p-8 lg:p-10 flex flex-row gap-6 items-start"
                    >
                        <div
                            class="w-16 h-16 shrink-0 rounded-2xl bg-base-200 flex items-center justify-center text-base-content group-hover:bg-secondary group-hover:text-secondary-content transition-colors duration-300"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="w-8 h-8"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h2
                                class="text-2xl font-bold text-base-content mb-2 group-hover:text-secondary transition-colors"
                            >
                                Contact Support
                            </h2>
                            <p
                                class="text-base-content/70 text-sm leading-relaxed mb-4"
                            >
                                Need human assistance? Call our dedicated
                                helpline or send us a direct message for
                                specialized technical or billing support.
                            </p>
                            <span
                                class="text-secondary font-semibold text-sm flex items-center gap-1"
                                >Get in Touch <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    viewBox="0 0 20 20"
                                    fill="currentColor"
                                    class="w-4 h-4"
                                    ><path
                                        fill-rule="evenodd"
                                        d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                                        clip-rule="evenodd"></path></svg
                                ></span
                            >
                        </div>
                    </div>
                </a>

                <div
                    class="card bg-base-100 border border-base-200 shadow-none opacity-80 cursor-not-allowed"
                >
                    <div
                        class="card-body p-8 lg:p-10 flex flex-row gap-6 items-start relative"
                    >
                        <span
                            class="badge badge-neutral absolute top-6 right-6 font-semibold text-xs"
                            >Coming Soon</span
                        >
                        <div
                            class="w-16 h-16 shrink-0 rounded-2xl bg-base-200 flex items-center justify-center text-base-content/50"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="w-8 h-8"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 010 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 010-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h2
                                class="text-2xl font-bold text-base-content/80 mb-2"
                            >
                                Complaint Helpdesk
                            </h2>
                            <p
                                class="text-base-content/50 text-sm leading-relaxed"
                            >
                                Soon you will be able to log in to create
                                trackable support tickets, monitor technician
                                dispatch, and view your repair history.
                            </p>
                        </div>
                    </div>
                </div>

                <div
                    class="card bg-base-100 border border-base-200 shadow-none opacity-80 cursor-not-allowed"
                >
                    <div
                        class="card-body p-8 lg:p-10 flex flex-row gap-6 items-start relative"
                    >
                        <span
                            class="badge badge-neutral absolute top-6 right-6 font-semibold text-xs"
                            >Coming Soon</span
                        >
                        <div
                            class="w-16 h-16 shrink-0 rounded-2xl bg-base-200 flex items-center justify-center text-base-content/50"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="w-8 h-8"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h2
                                class="text-2xl font-bold text-base-content/80 mb-2"
                            >
                                Network Status
                            </h2>
                            <p
                                class="text-base-content/50 text-sm leading-relaxed"
                            >
                                Check real-time outage maps, scheduled
                                maintenance windows, and fiber line statuses in
                                your specific sector or society.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>
