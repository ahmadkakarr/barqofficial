---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Barq - Next-Generation Connectivity">
    <div
        class="relative min-h-[85vh] flex items-center justify-center bg-base-300 overflow-hidden px-4 py-20 lg:py-0"
    >
        <div
            class="absolute inset-0 bg-gradient-to-br from-base-300 via-base-200 to-primary/10 z-0"
        >
        </div>
        <div
            class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/20 rounded-full mix-blend-multiply filter blur-[100px] opacity-50 animate-pulse"
        >
        </div>
        <div
            class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-secondary/20 rounded-full mix-blend-multiply filter blur-[100px] opacity-50 animate-pulse"
        >
        </div>

        <div
            class="relative z-10 max-w-[1440px] mx-auto w-full flex flex-col items-center"
        >
            <div class="text-center mb-16 px-4">
                <h1
                    class="text-5xl md:text-7xl font-black text-base-content tracking-tight mb-6"
                >
                    Next-Generation <span class="text-primary"
                        >Connectivity</span
                    >
                </h1>
                <p
                    class="text-lg md:text-xl text-base-content/70 max-w-2xl mx-auto"
                >
                    Experience lightning-fast internet tailored for your
                    lifestyle. Choose the technology that fits your home or
                    business.
                </p>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full max-w-5xl px-4"
            >
                <div
                    class="card bg-base-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-base-200 hover:-translate-y-2 hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] transition-all duration-300"
                >
                    <div class="card-body items-center text-center p-8 md:p-12">
                        <div
                            class="w-20 h-20 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 text-primary rotate-3"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="w-10 h-10"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"
                                ></path>
                            </svg>
                        </div>
                        <h2
                            class="card-title text-3xl font-bold mb-4 text-base-content"
                        >
                            Barq Fiber
                        </h2>
                        <p
                            class="text-base-content/70 mb-8 flex-grow leading-relaxed"
                        >
                            Ultra-low latency and gigabit speeds delivered
                            straight to your home. Perfect for competitive
                            gaming, 4K streaming, and heavy lifting.
                        </p>
                        <div class="card-actions w-full mt-auto">
                            <a
                                href="/subscriptions"
                                class="btn btn-primary btn-block rounded-full shadow-md shadow-primary/20 hover:shadow-primary/40 text-lg font-bold"
                            >
                                Explore Fiber
                            </a>
                        </div>
                    </div>
                </div>

                <div
                    class="card bg-base-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-base-200 hover:-translate-y-2 hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] transition-all duration-300"
                >
                    <div class="card-body items-center text-center p-8 md:p-12">
                        <div
                            class="w-20 h-20 bg-secondary/10 rounded-2xl flex items-center justify-center mb-6 text-secondary -rotate-3"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="w-10 h-10"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.106-1.061.212a.75.75 0 01-.893-.893l.212-1.061.106-.53a.75.75 0 011.5 0l.106.53.212 1.061a.75.75 0 01-.893.893l-1.061-.212-.53-.106z"
                                ></path>
                                <path
                                    d="M12 21v-3"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                                <path
                                    d="M8 21h8"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg>
                        </div>
                        <h2
                            class="card-title text-3xl font-bold mb-4 text-base-content"
                        >
                            Barq Wireless
                        </h2>
                        <p
                            class="text-base-content/70 mb-8 flex-grow leading-relaxed"
                        >
                            Reaching further with enterprise-grade Ubiquiti
                            technology. Reliable, high-speed connections without
                            the need for underground cables.
                        </p>
                        <div class="card-actions w-full mt-auto">
                            <a
                                href="/subscriptions"
                                class="btn btn-secondary btn-block rounded-full shadow-md shadow-secondary/20 hover:shadow-secondary/40 text-secondary-content text-lg font-bold"
                            >
                                Explore Wireless
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div
                class="flex flex-wrap justify-center gap-6 md:gap-12 mt-16 px-4"
            >
                <div class="flex items-center gap-3">
                    <div
                        class="w-8 h-8 rounded-full bg-success/20 flex items-center justify-center text-success"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="3"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                    </div>
                    <span class="font-semibold text-base-content/80"
                        >99.9% Uptime</span
                    >
                </div>
                <div class="flex items-center gap-3">
                    <div
                        class="w-8 h-8 rounded-full bg-success/20 flex items-center justify-center text-success"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="3"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                    </div>
                    <span class="font-semibold text-base-content/80"
                        >No Data Caps</span
                    >
                </div>
                <div class="flex items-center gap-3">
                    <div
                        class="w-8 h-8 rounded-full bg-success/20 flex items-center justify-center text-success"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="3"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                    </div>
                    <span class="font-semibold text-base-content/80"
                        >24/7 Support</span
                    >
                </div>
            </div>
        </div>
    </div>
</Layout>
