---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Coverage Areas - Barq Telecommunication">
    <div
        class="min-h-screen bg-base-100 flex flex-col pb-12 lg:pb-24 pt-16 lg:pt-24"
    >
        <section class="w-full px-4 text-center max-w-5xl mx-auto mb-20">
            <div
                class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-5xl md:text-6xl lg:text-7xl font-black text-base-content tracking-tight uppercase leading-none"
            >
                <span>GET READY TO</span>

                <div
                    class="h-[1em] w-[280px] md:w-[380px] lg:w-[460px] overflow-hidden inline-block relative text-primary align-bottom text-left"
                >
                    <ul class="animate-word-rotate list-none m-0 p-0 w-full">
                        <li class="h-[1em] block">CONNECT.</li>
                        <li class="h-[1em] block">STREAM.</li>
                        <li class="h-[1em] block">DOWNLOAD.</li>
                        <li class="h-[1em] block">GAME.</li>
                        <li class="h-[1em] block">SCALE.</li>
                        <li class="h-[1em] block">CONNECT.</li>
                    </ul>
                </div>
            </div>
            <p
                class="text-base-content/60 text-lg mt-8 max-w-2xl mx-auto font-medium"
            >
                Experience ultra-fast, reliable internet exclusively across our
                primary coverage zones. Both Fiber and Wireless solutions are
                fully available in your area.
            </p>
        </section>

        <section
            class="w-full max-w-5xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8"
        >
            <div
                class="card bg-base-200 border border-base-300 shadow-xl hover:-translate-y-2 transition-transform duration-300"
            >
                <div class="card-body items-center text-center p-8 lg:p-10">
                    <div
                        class="w-20 h-20 rounded-2xl bg-base-300 flex items-center justify-center mb-4 text-base-content"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-10 w-10"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2.5"
                                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                            ></path>
                        </svg>
                    </div>
                    <h2 class="card-title text-3xl font-black mb-3">
                        Bahria Town Lahore
                    </h2>

                    <div class="flex flex-wrap justify-center gap-2 mb-4">
                        <div
                            class="badge badge-primary badge-outline font-bold border-2 py-3 px-4"
                        >
                            Barq Fiber
                        </div>
                        <div
                            class="badge badge-info badge-outline font-bold border-2 py-3 px-4 text-[#0EA5E9]"
                        >
                            Wireless Broadband
                        </div>
                    </div>

                    <p class="text-base-content/70 mt-2">
                        Complete sector coverage with your choice of our
                        blazing-fast fiber optic network or our highly stable
                        wireless broadband solutions.
                    </p>
                </div>
            </div>

            <div
                class="card bg-base-200 border border-base-300 shadow-xl hover:-translate-y-2 transition-transform duration-300"
            >
                <div class="card-body items-center text-center p-8 lg:p-10">
                    <div
                        class="w-20 h-20 rounded-2xl bg-base-300 flex items-center justify-center mb-4 text-base-content"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-10 w-10"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2.5"
                                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                            ></path>
                        </svg>
                    </div>
                    <h2 class="card-title text-3xl font-black mb-3">
                        Bahria Orchard
                    </h2>

                    <div class="flex flex-wrap justify-center gap-2 mb-4">
                        <div
                            class="badge badge-primary badge-outline font-bold border-2 py-3 px-4"
                        >
                            Barq Fiber
                        </div>
                        <div
                            class="badge badge-info badge-outline font-bold border-2 py-3 px-4 text-[#0EA5E9]"
                        >
                            Wireless Broadband
                        </div>
                    </div>

                    <p class="text-base-content/70 mt-2">
                        Seamless connectivity across all phases. Choose between
                        our dedicated fiber lines or our rapid-deployment
                        wireless broadband.
                    </p>
                </div>
            </div>
        </section>
    </div>
</Layout>

<style is:global>
    .animate-word-rotate {
        animation: spinWords 10s infinite cubic-bezier(0.8, 0, 0.2, 1);
    }

    /* Moves up exactly 1 word height at a time (100% / 6 words = 16.666%) */
    @keyframes spinWords {
        0%,
        15% {
            transform: translateY(0%);
        }
        20%,
        35% {
            transform: translateY(-16.666%);
        }
        40%,
        55% {
            transform: translateY(-33.333%);
        }
        60%,
        75% {
            transform: translateY(-50%);
        }
        80%,
        95% {
            transform: translateY(-66.666%);
        }
        100% {
            transform: translateY(-83.333%);
        }
    }
</style>
